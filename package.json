{
  "name": "whalet",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @whalet/api start:dev",
    "dev:all": "pnpm --filter @whalet/api start:dev & pnpm --filter @whalet/web dev",
    "build": "pnpm --filter @whalet/api build",
    "build:api": "pnpm --filter @whalet/api build",
    "build:web": "pnpm --filter @whalet/web build",
    "lint": "pnpm --filter @whalet/api lint",
    "test": "pnpm --filter @whalet/api test",
    "typecheck": "pnpm --filter @whalet/api exec tsc --noEmit",
    "prisma:generate": "pnpm --filter @whalet/api prisma:generate",
    "prisma:migrate": "pnpm --filter @whalet/api prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter @whalet/api prisma:migrate:deploy",
    "prisma:seed": "pnpm --filter @whalet/api prisma:seed",
    "prisma:studio": "pnpm --filter @whalet/api prisma:studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "env:setup": "cp .env.example .env && ln -sf ../../.env apps/api/.env && echo 'Done: .env created and apps/api/.env symlinked'"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
